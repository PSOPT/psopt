# _toolchain.py -- GENERATED by CMake (configure_file) from the compiler and flags
# that built libPSOPT.  Do not edit by hand; it is regenerated on every configure.
#
# codegen.py imports CXX, CXXFLAGS, INCLUDES, LIBS and CACHE_DIR from here to
# JIT-compile each problem's adouble math .so.  The .so performs adouble
# arithmetic only and links CppAD; PSOPT's own symbols (e.g. auto_link) resolve
# at load time from the whole-archived _psopt extension under RTLD_GLOBAL.
import os

CXX      = "@PSOPT_PY_CXX@"
CXXFLAGS = [@PSOPT_PY_CXXFLAGS@]
INCLUDES = [@PSOPT_PY_INCLUDES@]
LIBS     = [@PSOPT_PY_LIBS@]

# Writable, per-user cache for the generated .so files (overridable via env).
CACHE_DIR = os.environ.get("PSOPT_CACHE_DIR") or os.path.join(
    os.environ.get("XDG_CACHE_HOME", os.path.join(os.path.expanduser("~"), ".cache")),
    "psopt",
)
